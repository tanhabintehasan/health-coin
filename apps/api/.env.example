# Database
DATABASE_URL=postgresql://username:password@localhost:5432/healthcoin_db

# JWT
JWT_SECRET=change_this_to_a_secure_random_string
JWT_EXPIRES_IN=2h
JWT_REFRESH_SECRET=change_this_to_a_different_secure_random_string
JWT_REFRESH_EXPIRES_IN=7d

# App
NODE_ENV=development
PORT=10000
APP_URL=http://localhost:10000
CORS_ORIGINS=http://localhost:5173,http://localhost:3001,http://localhost:3002

# Demo login (temporary — set to true for client review without OTP/SMS)
DEMO_LOGIN_ENABLED=false

# Cron secret for protecting /admin/cron endpoints
CRON_SECRET=change_this_to_a_secure_random_string

# OSS (optional for local dev)
OSS_REGION=oss-cn-hangzhou
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=healthcoin-files
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com

# Fuiou Payment (optional for local dev)
FUIOU_MERCHANT_NO=
FUIOU_API_KEY=
FUIOU_GATEWAY_URL=https://pay.fuiou.com
